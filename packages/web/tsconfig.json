{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "preserve",
    "noEmit": true,
    "types": ["vitest/globals"],
    "resolveJsonModule": true,
    "paths": { "@/*": ["./*"] },
    "plugins": [{ "name": "next" }],
    "allowJs": true,
    "incremental": true,
    "isolatedModules": true
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
